# Server Configuration
PORT=5000
NODE_ENV=development
API_PREFIX=/api

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ecommerce

# Redis Cache Configuration
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# JWT Authentication
JWT_SECRET=super_secret_access_token_key_change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super_secret_refresh_token_key_change_me_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Email SMTP Configuration (e.g., Mailtrap / SendGrid)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@ecommerce.com

# Stripe Payments (Mock / Live)
STRIPE_SECRET_KEY=sk_test_mock_payment_key_12345
STRIPE_WEBHOOK_SECRET=whsec_mock_webhook_secret_12345
CLIENT_URL=http://localhost:3000
